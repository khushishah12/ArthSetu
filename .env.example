# Neon PostgreSQL — copy the pooled connection string from Neon.
DATABASE_URL=

# Neon Auth — copy the Auth URL from Neon Console → Auth.
NEON_AUTH_BASE_URL=
# Generate once and keep stable. Minimum 32 characters.
NEON_AUTH_COOKIE_SECRET=

# FastAPI ML engine. Keep these server-side.
ML_SERVICE_URL=http://127.0.0.1:8000
ML_SERVICE_API_KEY=local-development-key
ALLOW_DEMO_FALLBACK=true

NEXT_PUBLIC_SITE_URL=http://localhost:3000
